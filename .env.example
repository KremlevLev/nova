# Cloud providers
GROQ_API_KEYS=
OPENROUTER_API_KEYS=

# Local STT: whisper.cpp
# Рекомендуется ggml-tiny.bin или ggml-base.bin.
NOVA_LOCAL_STT_EXECUTABLE=
NOVA_LOCAL_STT_MODEL=
NOVA_LOCAL_STT_LANGUAGE=ru
NOVA_LOCAL_STT_TIMEOUT=120

# Local LLM: llama.cpp
# Рекомендуется 1–3B Q4_K_M GGUF.
NOVA_LOCAL_LLM_EXECUTABLE=
NOVA_LOCAL_LLM_MODEL=
NOVA_LOCAL_LLM_CONTEXT=4096
NOVA_LOCAL_LLM_MAX_TOKENS=384
NOVA_LOCAL_LLM_TEMPERATURE=0.2
NOVA_LOCAL_LLM_THREADS=4
NOVA_ENABLE_LOCAL_LLM_FALLBACK=true

NOVA_WAKE_WORD_ENABLED=true
NOVA_WAKE_WORD=нова
NOVA_VOSK_MODEL=data/models/vosk
NOVA_WAKE_WORD_SENSITIVITY=0.55
NOVA_WAKE_COMMAND_TIMEOUT=15

# MCP Servers
GITHUB_TOKEN=
SLACK_TOKEN=
MCP_SQLITE_PATH=nova_memory.db
GOOGLE_DRIVE_TOKEN=